def rectangle_exchange(x, y, a, b):
    if Ge(x, a):
        return (x - a, y), 1
    elif Lt(x, a) and Ge(y, b):
        return (x + 1 - a, y - b), 2
    else:
        return (x + 1 - a, y + 1 - b), 3

def iterate(x, y, a, b, steps):
    trajectory, regions = [(x, y)], []
    if Ge(x, a):
        regions.append(1)
    elif Lt(x, a) and Ge(y, b):
        regions.append(2)
    else:
        regions.append(3)

    curr_x, curr_y = x, y
    for _ in tqdm(range(steps), desc="Iterace fázové trajektorie"):
        (curr_x, curr_y), region = rectangle_exchange(curr_x, curr_y, a, b)
        trajectory.append((curr_x, curr_y))
        if Ge(curr_x, a):
            regions.append(1)
        elif Lt(curr_x, a) and Ge(curr_y, b):
            regions.append(2)
        else:
            regions.append(3)
    return trajectory, regions

def phi_transform(x, y):
    return x, y - (1 - b_f) * x

def draw_grid(ax, lines_count=10, x_min=-2, x_max=2, samples=500,
              color='gray', linestyle=':', linewidth=1, alpha=0.3, transform=None):
    vals = np.linspace(x_min, x_max, 4 * lines_count + 1)
    t = np.linspace(x_min, x_max, samples)

    for v in vals:
        x_orig = t
        y_orig = np.full_like(t, v)
        if transform is not None:
            x_plot, y_plot = transform(x_orig, y_orig)
        else:
            x_plot, y_plot = x_orig, y_orig
        ax.plot(x_plot, y_plot, color=color, linestyle=linestyle,
                linewidth=linewidth, alpha=alpha)

    for v in vals:
        x_orig = np.full_like(t, v)
        y_orig = t
        if transform is not None:
            x_plot, y_plot = transform(x_orig, y_orig)
        else:
            x_plot, y_plot = x_orig, y_orig
        ax.plot(x_plot, y_plot, color=color, linestyle=linestyle,
                linewidth=linewidth, alpha=alpha)

def draw_transformed_grid(ax, lines_count=10, alpha=0.4):
    vals = np.linspace(0, 1, 11)
    t = np.linspace(0, 1, 500)
    
    for v in vals:
        # Původně horizontální čáry
        x_orig = t
        y_trans = (v - (1 - b_f) * x_orig) % 1.0
        # Odstranění spojnic při přetečení přes hranu (skok o více než 0.5)
        jumps = np.abs(np.diff(y_trans)) > 0.5
        y_trans[np.insert(jumps, 0, False)] = np.nan
        ax.plot(x_orig, y_trans, color='gray', linestyle=':', linewidth=1, alpha=alpha)

        # Původně vertikální čáry
        x_trans = np.full_like(t, v)
        y_trans_v = (t - (1 - b_f) * x_trans) % 1.0
        jumps_v = np.abs(np.diff(y_trans_v)) > 0.5
        y_trans_v[np.insert(jumps_v, 0, False)] = np.nan
        ax.plot(x_trans, y_trans_v, color='gray', linestyle=':', linewidth=1, alpha=alpha)

