def presny_zapis(a_cit, a_jmen, b_cit, b_jmen, d):
    if a_jmen == 0 or b_jmen == 0 or d < 0:
        return None
    return Rational(a_cit, a_jmen) + Rational(b_cit, b_jmen) * sqrt(d)

def lcm_denom(q1, q2):
    if q1 == 0 and q2 != 0:
        return denom(q2)
    elif q2 == 0 and q1 != 0:
        return denom(q1)
    else: return lcm(denom(q1), denom(q2))

# --- Parametry ---

a = presny_zapis(0, 2, 1, 3, 2)
b = presny_zapis(0, 4, 1, 2, 2)
a_conj = presny_zapis(0, 2, -1, 3, 2)
b_conj = presny_zapis(0, 4, -1, 2, 2)
