    delky_podle_regionu = {1: [Rational(0, 1), Rational(0, 1)], 
                           2: [Rational(0, 1), Rational(0, 1)], 
                           3: [Rational(0, 1), Rational(0, 1)]} 
    
    s_f = float(s.evalf())
    a_f = float(a.evalf())
    b_f = float(b.evalf())
    
    for i in tqdm(range(-u_int - 50, u_int + 50), desc="Výpočet analytických délek"):
        current_off = Rational(i, u) + offset_base
        off_f = float(current_off.evalf())
        
        exact_x_cands = [Rational(0, 1), a, Rational(1, 1)]
        if s != 0:
            for y_edge_sym in [Rational(0, 1), b, Rational(1, 1)]:
                exact_x_cands.append(simplify((y_edge_sym - current_off) / s))
                
        valid_exact_x = []
        for cx in exact_x_cands:
            val = float(cx.evalf())
            if -1e-7 <= val <= 1.0 + 1e-7:
                valid_exact_x.append(cx)
                
        valid_exact_x.sort(key=lambda cx: float(cx.evalf()))
        
        # Odstranění duplicit
        unique_exact_x = []
        for cx in valid_exact_x:
            if not unique_exact_x or abs(float(cx.evalf()) - float(unique_exact_x[-1].evalf())) > 1e-9:
                unique_exact_x.append(cx)
                
        # Samotný výpočet
        for j in range(len(unique_exact_x) - 1):
            x_s_sym = unique_exact_x[j]
            x_e_sym = unique_exact_x[j + 1]
            
            x_mid_sym = (x_s_sym + x_e_sym) / 2
            x_mid_f = float(x_mid_sym.evalf())
            y_mid_f = s_f * x_mid_f + off_f
            
            if y_mid_f < -1e-9 or y_mid_f > 1.0 + 1e-9:
                continue
                
            if x_mid_f >= a_f: reg = 1
            elif y_mid_f >= b_f: reg = 2
            else: reg = 3

            dx_sym = simplify(x_e_sym - x_s_sym)
            
            l1 = simplify(dx_sym * delka_nasobic_g1)
            l_1.append(l1)
            l2 = simplify(dx_sym * delka_nasobic_g2)
            l_2.append(l2)
            
            celkova_delka_g1 = simplify(celkova_delka_g1 + l1)
            celkova_delka_g2 = simplify(celkova_delka_g2 + l2)
            delky_podle_regionu[reg][0] = simplify(delky_podle_regionu[reg][0] + l1)
            delky_podle_regionu[reg][1] = simplify(delky_podle_regionu[reg][1] + l2)
    """        
    print("\n--- Délky jednotlivých úseků v Grafu 1 ---")
    print(l_1)
    print("\n--- Délky jednotlivých úseků v Grafu 2 ---")
    print(l_2)
    print()
    """
    
    return celkova_delka_g1, celkova_delka_g2, delky_podle_regionu

celk_g1, celk_g2, region_delky = vypocet_presnych_delek(s, tilde_s, a, b, offset_base, u, u_int)

