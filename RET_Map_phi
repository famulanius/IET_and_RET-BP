for i in range(-u_int - 50, u_int + 50):
    current_off = Rational(i, u) + offset_base
    off_f = float(current_off.evalf())

    x_candidates = {0.0, a_f, 1.0}
    
    # 1. Průsečíky s vnějšími horizontálními okraji (y=0, y=1) hledáme pro celé x
    for y_edge in [0.0, 1.0]:
        x_sol = (y_edge - off_f) / s_f if abs(s_f) > epsilon else None
        if x_sol is not None and 0.0 <= x_sol <= 1.0:
            x_candidates.add(float(x_sol))

    # 2. Průsečík s hranicí y=beta přidáme pouze pokud leží vlevo od alpha (nebo na ní)
    x_sol_beta = (b_f - off_f) / s_f if abs(s_f) > epsilon else None
    if x_sol_beta is not None and 0.0 <= x_sol_beta <= a_f + epsilon:
        x_candidates.add(float(x_sol_beta))

    sorted_x = sorted(x_candidates)
    for j in range(len(sorted_x) - 1):
        x_s, x_e = sorted_x[j], sorted_x[j + 1]
        if x_e - x_s < epsilon:
